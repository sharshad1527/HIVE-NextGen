{
    "name": "Highlight",
    "icon": "mdi6.format-color-highlight",
    "category": "captions",
    "properties": {
        "Font Family": {"type": "font", "default": "Inter"},
        "Font Size": {"type": "slider", "min": 10, "max": 200, "default": 52, "suffix": "px"},
        "Text Color": {"type": "color", "default": "#FFFFFF"},
        "Bg Color": {"type": "color", "default": "#FFD700"},
        "bg_opacity": {"type": "slider", "min": 0, "max": 100, "default": 80, "suffix": "%"},
        "bg_radius": {"type": "slider", "min": 0, "max": 50, "default": 6, "suffix": "px"},
        "bg_padding": {"type": "slider", "min": 0, "max": 50, "default": 8, "suffix": "px"},
        "outline_width": {"type": "slider", "min": 0, "max": 10, "default": 3, "suffix": "px"},
        "outline_color": {"type": "color", "default": "#000000"},
        "max_chars_per_line": {"type": "slider", "min": 5, "max": 80, "default": 35},
        "max_lines": {"type": "slider", "min": 1, "max": 8, "default": 2},
        "word_wrap": {"type": "checkbox", "default": true},
        "text_align": {"type": "combo", "options": ["Left", "Center", "Right"], "default": "Center"},
        "font_weight": {"type": "combo", "options": ["Regular", "Bold", "Light", "Black"], "default": "Bold"},
        "Position_X": {"type": "slider", "min": -9999, "max": 9999, "default": 0},
        "Position_Y": {"type": "slider", "min": -9999, "max": 9999, "default": 350}
    },
    "controls_schema": [
        {
            "section": "Content",
            "controls": [
                {"key": "text", "type": "text", "default": "", "placeholder": "Enter caption...", "label": "Text"}
            ]
        },
        {
            "section": "Typography",
            "controls": [
                {"key": "Font Family", "type": "font", "default": "Inter", "label": "Font"},
                {"key": "Font Size", "type": "slider", "min": 8, "max": 300, "default": 52, "suffix": "px", "label": "Size"},
                {"key": "font_weight", "type": "combo", "options": ["Regular", "Bold", "Light", "Black"], "default": "Bold", "label": "Weight"},
                {"key": "Text Color", "type": "color", "default": "#FFFFFF", "label": "Text Color"}
            ]
        },
        {
            "section": "Highlight Background",
            "controls": [
                {"key": "Bg Color", "type": "color", "default": "#FFD700", "label": "Highlight Color"},
                {"key": "bg_opacity", "type": "slider", "min": 0, "max": 100, "default": 80, "suffix": "%", "label": "Highlight Opacity"},
                {"key": "bg_radius", "type": "slider", "min": 0, "max": 50, "default": 6, "suffix": "px", "label": "Corner Radius"},
                {"key": "bg_padding", "type": "slider", "min": 0, "max": 50, "default": 8, "suffix": "px", "label": "Padding"}
            ]
        },
        {
            "section": "Text Layout",
            "controls": [
                {"key": "max_chars_per_line", "type": "slider", "min": 5, "max": 80, "default": 35, "suffix": " chars", "label": "Line Width"},
                {"key": "max_lines", "type": "slider", "min": 1, "max": 8, "default": 2, "label": "Max Lines"},
                {"key": "word_wrap", "type": "checkbox", "default": true, "label": "Word Wrap"},
                {"key": "text_align", "type": "combo", "options": ["Left", "Center", "Right"], "default": "Center", "label": "Alignment"}
            ]
        },
        {
            "section": "Outline",
            "controls": [
                {"key": "outline_width", "type": "slider", "min": 0, "max": 15, "default": 3, "suffix": "px", "label": "Outline"},
                {"key": "outline_color", "type": "color", "default": "#000000", "label": "Outline Color"}
            ]
        },
        {
            "section": "Transform",
            "controls": [
                {"key": "Position_X", "type": "slider", "min": -9999, "max": 9999, "default": 0, "label": "Position X"},
                {"key": "Position_Y", "type": "slider", "min": -9999, "max": 9999, "default": 350, "label": "Position Y"},
                {"key": "Scale", "type": "slider", "min": 10, "max": 400, "default": 100, "suffix": "%", "label": "Scale"},
                {"key": "Rotation", "type": "slider", "min": -180, "max": 180, "default": 0, "suffix": "°", "label": "Rotation"},
                {"key": "Opacity", "type": "slider", "min": 0, "max": 100, "default": 100, "suffix": "%", "label": "Opacity"}
            ]
        }
    ]
}
