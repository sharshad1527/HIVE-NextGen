{
    "name": "Standard",
    "icon": "mdi6.closed-caption-outline",
    "category": "captions",
    "properties": {
        "font_family": {"type": "combo", "options": ["Roboto", "Arial", "Sour Gummy", "Montserrat", "Inter", "Poppins"], "default": "Roboto"},
        "font_size": {"type": "slider", "min": 10, "max": 200, "default": 48, "suffix": ""},
        "text_color": {"type": "color", "default": "#FFFFFF"},
        "bg_color": {"type": "color", "default": "transparent"},
        "bg_opacity": {"type": "slider", "min": 0, "max": 100, "default": 0, "suffix": "%"},
        "position_y": {"type": "slider", "min": -500, "max": 500, "default": 350, "suffix": "px"},
        "outline_width": {"type": "slider", "min": 0, "max": 10, "default": 2, "suffix": "px"},
        "outline_color": {"type": "color", "default": "#000000"}
    }
}
