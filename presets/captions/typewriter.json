{
    "name": "Typewriter",
    "icon": "mdi6.typewriter",
    "category": "captions",
    "properties": {
        "font_family": {"type": "font", "default": "Courier New"},
        "font_size": {"type": "slider", "min": 10, "max": 200, "default": 44, "suffix": ""},
        "text_color": {"type": "color", "default": "#00FF88"},
        "bg_color": {"type": "color", "default": "#0a0a0a"},
        "bg_opacity": {"type": "slider", "min": 0, "max": 100, "default": 80, "suffix": "%"},
        "outline_width": {"type": "slider", "min": 0, "max": 10, "default": 0, "suffix": "px"}
    },
    "controls_schema": [
        {
            "section": "Content",
            "controls": [
                {"key": "text", "type": "text", "default": "", "placeholder": "Enter typewriter text...", "label": "Text"}
            ]
        },
        {
            "section": "Typography",
            "controls": [
                {"key": "Font Family", "type": "font", "default": "Courier New", "label": "Font"},
                {"key": "Font Size", "type": "slider", "min": 8, "max": 300, "default": 44, "suffix": "px", "label": "Size"},
                {"key": "font_weight", "type": "combo", "options": ["Regular", "Bold", "Light"], "default": "Regular", "label": "Weight"},
                {"key": "Text Color", "type": "color", "default": "#00FF88", "label": "Text Color"}
            ]
        },
        {
            "section": "Background",
            "controls": [
                {"key": "Bg Color", "type": "color", "default": "#0a0a0a", "label": "Background"},
                {"key": "bg_opacity", "type": "slider", "min": 0, "max": 100, "default": 80, "suffix": "%", "label": "BG Opacity"}
            ]
        },
        {
            "section": "Text Layout",
            "controls": [
                {"key": "max_chars_per_line", "type": "slider", "min": 5, "max": 80, "default": 50, "suffix": " chars", "label": "Line Width"},
                {"key": "max_lines", "type": "slider", "min": 1, "max": 8, "default": 3, "label": "Max Lines"},
                {"key": "word_wrap", "type": "checkbox", "default": true, "label": "Word Wrap"},
                {"key": "text_align", "type": "combo", "options": ["Left", "Center", "Right"], "default": "Left", "label": "Alignment"}
            ]
        },
        {
            "section": "Transform",
            "controls": [
                {"key": "position", "type": "xy", "min": -9999, "max": 9999, "default_x": 0, "default_y": 300, "label": "Position"},
                {"key": "Scale", "type": "slider", "min": 10, "max": 400, "default": 100, "suffix": "%", "label": "Scale"},
                {"key": "Opacity", "type": "slider", "min": 0, "max": 100, "default": 100, "suffix": "%", "label": "Opacity"}
            ]
        }
    ]
}
