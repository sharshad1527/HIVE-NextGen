{
    "name": "Slide",
    "icon": "mdi6.transition",
    "category": "transitions",
    "properties": {
        "duration": {"type": "slider", "min": 5, "max": 60, "default": 15, "suffix": " frames"},
        "direction": {"type": "combo", "options": ["Left", "Right", "Up", "Down"], "default": "Left"},
        "easing": {"type": "combo", "options": ["Linear", "Ease In", "Ease Out", "Ease In-Out"], "default": "Ease In-Out"}
    },
    "controls_schema": [
        {
            "section": "Transition",
            "controls": [
                {"key": "transition_in_duration_sec", "type": "float_spin", "min": 0.1, "max": 8.0, "default": 0.5, "step": 0.1, "suffix": "s", "label": "Speed"},
                {"key": "direction", "type": "combo", "options": ["Left", "Right", "Up", "Down"], "default": "Left", "label": "Direction"},
                {"key": "easing", "type": "combo", "options": ["Linear", "Ease In", "Ease Out", "Ease In-Out"], "default": "Ease In-Out", "label": "Easing"}
            ]
        }
    ]
